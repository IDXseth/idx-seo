// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  password      String?        // null for OAuth users
  gscSiteUrl    String?        // selected Google Search Console property URL — SQL: ALTER TABLE "User" ADD COLUMN IF NOT EXISTS "gscSiteUrl" TEXT;
  createdAt     DateTime       @default(now())
  accounts      Account[]
  sessions      Session[]
  batches       Batch[]
  sharedBatches ProjectShare[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProjectShare {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  email     String   // invited email
  userId    String?  // set when the invited user signs up/logs in
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([batchId, email])
}

model Batch {
  id          String         @id @default(cuid())
  name        String
  fileName    String
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPrivate   Boolean        @default(true)
  shareToken  String?        @unique @default(cuid())
  prompts     Prompt[]
  shares      ProjectShare[]
  runs        BatchRun[]
  runSessions RunSession[]
  schedules   Schedule[]
  createdAt   DateTime       @default(now())
}

model BatchRun {
  id           String      @id @default(cuid())
  batchId      String?
  batch        Batch?      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  runSessionId String?
  runSession   RunSession? @relation(fields: [runSessionId], references: [id])
  totalPrompts Int
  doneCount    Int         @default(0)
  failCount    Int         @default(0)
  notifyEmail  String?
  status       String      @default("running")  // "running" | "done"
  startedAt    DateTime    @default(now())
  finishedAt   DateTime?
}

model RunSession {
  id          String     @id @default(cuid())
  batchId     String?
  batch       Batch?     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  triggeredBy String     @default("manual")  // "manual" | "scheduled"
  scheduleId  String?
  schedule    Schedule?  @relation(fields: [scheduleId], references: [id])
  status      String     @default("running")  // "running" | "done"
  batchRuns   BatchRun[]
  results     Result[]
  startedAt   DateTime   @default(now())
  finishedAt  DateTime?
}

model Schedule {
  id          String       @id @default(cuid())
  batchId     String
  batch       Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  frequency   String       // "daily" | "weekly" | "monthly" | "custom"
  customDays  Int?         // days between runs, for "custom"
  dayOfWeek   Int?         // 0–6 (Sun=0), for "weekly"
  dayOfMonth  Int?         // 1–31, for "monthly"
  hour        Int          @default(9)
  timezone    String       @default("America/Chicago")
  enabled     Boolean      @default(true)
  nextRunAt   DateTime
  lastRunAt   DateTime?
  runSessions RunSession[]
  createdAt   DateTime     @default(now())
}

model Prompt {
  id            String   @id @default(cuid())
  batchId       String
  batch         Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  promptType    String   // "brand" | "nonbrand"
  category      String
  communityName String
  city          String
  market        String
  levelOfCare   String   // "Assisted Living" | "Independent Living" | "Memory Care" | "Skilled Nursing" | "Short Term Care" | ""
  promptText    String
  jobStatus     String   @default("pending")  // "pending" | "running" | "done" | "failed"
  jobError      String?
  results       Result[]
  createdAt     DateTime @default(now())
}

model Result {
  id           String      @id @default(cuid())
  promptId     String
  prompt       Prompt      @relation(fields: [promptId], references: [id], onDelete: Cascade)
  runSessionId String?
  runSession   RunSession? @relation(fields: [runSessionId], references: [id])
  platform     String      // "chatgpt" | "claude" | "perplexity" | "gemini" | "google_aio" | "google_ai_mode"
  responseText String
  isMentioned  Boolean     @default(false)
  isCited      Boolean     @default(false)
  sentiment    String      @default("neutral")  // "positive" | "neutral" | "negative"
  citations    Citation[]
  runAt        DateTime    @default(now())
}

model Citation {
  id       String @id @default(cuid())
  resultId String
  result   Result @relation(fields: [resultId], references: [id], onDelete: Cascade)
  url      String
  title    String
  domain   String
}

// Cache for Google Search Console metrics per page URL.
// Populated by the daily `refresh-gsc-cache` Inngest function.
// SQL: CREATE TABLE IF NOT EXISTS "GscMetric" ("id" TEXT NOT NULL PRIMARY KEY, "pageUrl" TEXT NOT NULL UNIQUE, "isIndexed" BOOLEAN NOT NULL DEFAULT false, "impressions" INTEGER NOT NULL DEFAULT 0, "clicks" INTEGER NOT NULL DEFAULT 0, "position" DOUBLE PRECISION, "fetchedAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP, "updatedAt" TIMESTAMP(3) NOT NULL);
model GscMetric {
  id          String   @id @default(cuid())
  pageUrl     String   @unique
  isIndexed   Boolean  @default(false)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  position    Float?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Cache for page-level schema markup detection.
// Populated by crawlCommunityPages() after each GSC sync.
// SQL: CREATE TABLE IF NOT EXISTS "PageCrawlResult" ("id" TEXT NOT NULL PRIMARY KEY, "pageUrl" TEXT NOT NULL UNIQUE, "hasLocalBusiness" BOOLEAN, "hasSeniorCare" BOOLEAN, "crawledAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP, "updatedAt" TIMESTAMP(3) NOT NULL);
model PageCrawlResult {
  id               String   @id @default(cuid())
  pageUrl          String   @unique
  hasLocalBusiness Boolean?
  hasSeniorCare    Boolean?
  crawledAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
