# Database (Supabase — use the direct connection string, NOT the transaction pooler)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI platform API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Email notifications (https://resend.com/)
RESEND_API_KEY=

# SearchAPI for Google AI Overviews / AI Mode (https://www.searchapi.io/)
SEARCHAPI_KEY=

# App URL (used for share links — set to your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
